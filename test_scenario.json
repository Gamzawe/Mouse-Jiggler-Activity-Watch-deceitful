{
  "scenarios": [
    {
      "name": "IdleTestSequence",
      "description": "Verifies system response after idle period.",
      "steps": [
        { "type": "waitIdle", "seconds": 30 },
        { "type": "mouseMove", "x": 100, "y": 200, "duration": 500 },
        { "type": "keyPress", "key": "A", "delay": 100 },
        { "type": "mouseClick", "button": "left" },
        { "type": "wait", "ms": 5000 },
        { "type": "verifyActiveWindow", "title": "Notepad" }
      ]
    },
    {
      "name": "SmokeTest",
      "description": "Basic UI smoke test.",
      "steps": [
        { "type": "launch", "app": "notepad.exe" },
        { "type": "typeText", "text": "Hello from test harness" },
        { "type": "wait", "ms": 2000 },
        { "type": "close", "app": "notepad.exe" }
      ]
    }
  ],
  "settings": {
    "reportPath": "C:\\ProgramData\\Logitech\\LogiOptions\\Reports\\",
    "failOnError": false,
    "yieldToRealUser": true
  }
}
